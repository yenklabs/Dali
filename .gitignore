# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl
MANIFEST

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
.envrc
secrets.json
secrets.yaml
secrets.toml
.secrets/

# ── Credential files (GCP, AWS, etc.) ─────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
service_account*.json
*service-account*.json
credentials.json
gcp-key*.json
*-keyfile.json
application_default_credentials.json

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
.idea/
.vscode/
.cursor/
*.swp
*.swo
*~

# ── Test / coverage artifacts ─────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ── Logs / local databases ────────────────────────────────────────────────────
*.log
*.sqlite
*.sqlite3
*.db

# ── Git authorship / tooling metadata ─────────────────────────────────────────
# .mailmap maps committer identities — not for public repos
.mailmap

# ── Internal / private data ───────────────────────────────────────────────────
# Un-anonymized corpus, attorney name lists, curation provenance
benchmarks/tier1/corpus/internal/

# Internal verification notes, testing run artifacts
docs/benchmark/

# Outreach drafts — negotiation strategy, not for public repo
docs/outreach/

# ── Results — run data ────────────────────────────────────────────────────────
# Ephemeral local smoke runs are ignored; versioned published runs are committed.
results/demo/*
!results/demo/.gitkeep
# To ignore a specific run: add results/v0.2/YYYY-MM-DD/ here explicitly.
!results/README.md
!results/v0.2/README.md
!results/v0.2/schema.json
!results/v0.2/methodology.template.json
